# Supabase (Frontend - Non-sensitive)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (Frontend - Publishable key only, safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# NOTE: The following should ONLY be set in Supabase Edge Functions secrets:
# - SUPABASE_SERVICE_ROLE_KEY (used by edge functions)
# - STRIPE_SECRET_KEY (used by edge functions)
# - STRIPE_WEBHOOK_SECRET (for webhook verification)